# ==============================
# SantéAI — .gitignore
# ==============================

# Script d'initialisation (contient la logique de hash) à supprimer après usage
setup.php

# Variables d'environnement
.env
.env.local
config/config.local.php

# Dépendances PHP (si Composer est ajouté plus tard)
vendor/
composer.lock

# Logs PHP
*.log
error.log
php_error.log

# Fichiers IDE / outils
.vscode/settings.json
.idea/
.github/
*.swp
*.swo
*.sublime-workspace

# Système d'exploitation
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# Fiches de révision personnelles (BTS SIO)
ORAL_PREPARATION.md

# Fichiers temporaires
*.tmp
*.bak
*.old

# Dépendances Node (npm)
node_modules/
package-lock.json

# ==============================
# Documentation et notes personnelles
# (gardées en local)
# ==============================
docs/
ORAL_PREPARATION.md
